import random

def random_letter():
    alphabet = "邪斜胁谐写械褢卸蟹懈泄泻谢屑薪芯锌褉褋褌褍褎褏褑褔褕褖褗褘褜褝褞褟"
    return random.choice(alphabet)

user_str = input("袙胁械写懈褌械 褋褌褉芯泻褍 屑懈薪懈屑褍屑 懈蟹 4 褋谢芯胁: ")
words = user_str.split()    #褉邪蟹写械谢褟械屑
if len(words) < 4:
    print("袧褍卸薪芯 胁胁械褋褌懈 屑懈薪懈屑褍屑 4 褋谢芯胁邪!")
else:
    result = []

    for word in words:
        word_len = len(word)
        if word.isdigit():
            new_word = ''
            for i in range(int(word)):      #锌芯胁褌芯褉褟械屑 word 泻芯谢懈褔械褋褌胁芯 褉邪蟹
                new_word += random_letter()
            result.append([new_word, str(word_len)])
        else:
            result.append([word, str(word_len)])

    print("\n袪械蟹褍谢褜褌邪褌 (褋谢芯胁芯, 写谢懈薪邪):")
    for item in result:
        print(f"{item[0]}, {item[1]}")
