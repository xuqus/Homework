# Вводится несколько двузначных (десятичных) чисел.
# Числа нужно собирать в цепочку по следующему правилу:
# У двух соседних чисел должно совпадать произведение цифр.
# Определить максимальную длину цепочки.
# Сначала вводится количество двузначных чисел n (n <= 1000),
# Затем сами двузначные числа через пробел
# Вывести количество чисел в цепочке.
# Пример ввода:            4
#                           3 22 14 32
# Результат: 2

sum_mass = []
result = 1  # потому что цепочка из одного символа уже существует
n = input("Введите двузначные числа через пробел: ")
n_mass = n.split()


for el in n_mass:
    summa = int(el[0])+int(el[1])
    sum_mass.append(summa)
for n in range(len(sum_mass) - 1):
    if sum_mass[n] == sum_mass[n+1]:
        result += 1
print(f"Результат: {result:2}")
