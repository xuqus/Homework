# 1.  Строится двоичная запись числа N.
n = int(input("Введите натуральное число: "))
n_copy = n  # создал для 4 задания, потому что n изменяется в коде
n_bin=""
while n > 0:
    n_bin = str(n % 2) + n_bin  # вначале остаток от деления + строка
    n = n//2
print(f"Число в двоичной системе счисления: {n_bin}")

# 2.  В полученной записи все нули заменяются на единицы, все единицы - на нули. Из полученного числа удаляются ведущие нули.
reverse_bin=""
for i in n_bin:
    if i == "0":
        reverse_bin += "1"
    elif i == "1":
        reverse_bin += "0"      # 0=1, 1=0
while len(reverse_bin) > 0 and reverse_bin[0] == "0":       # проверяет количество нулей в начале строки
    reverse_bin=reverse_bin[1:]     # срезаем ведущий ноль если он есть
print(f"Перевернутое число со срезанными нулями: {reverse_bin}")

# 3.  Результат переводится в десятичную систему счисления.
n_dec = 0
stepen = len(reverse_bin) - 1 # потому что заканчиваем не первой степенью, а нулевой
for i in reverse_bin:
    n_dec += int(i)*2**stepen       # цифру умножаем на 2 в степени
    stepen -= 1
print(f"Число в десятичной системе счисления: {n_dec}")

# 4.  Результатом работы алгоритма становится разность исходного числа N и числа, полученного на предыдущем шаге.
result = n_copy - n_dec
print(f"Результат вычитания {n_copy} - {n_dec} = {result}")
#5 Найти наименьшее значение N, при котором результат = 999
N = 1
while True:
    n = N
    n_bin = ""
    while n > 0:
        n_bin = str(n % 2) + n_bin
        n = n // 2
    
    reverse_bin = ""
    for i in n_bin:
        if i == "0":
            reverse_bin += "1"
        else:
            reverse_bin += "0"
    
    while len(reverse_bin) > 0 and reverse_bin[0] == "0":
        reverse_bin = reverse_bin[1:]
    
    if reverse_bin == "":
        reverse_bin = "0"
    
    n_dec = 0
    stepen = len(reverse_bin) - 1
    for i in reverse_bin:
        n_dec += int(i) * (2 ** stepen)
        stepen -= 1
    
    if N - n_dec == 999:
        print(f"Наименьшее N при котором результат = 999: {N}")
        break
    
    N = N + 1
